# Step 1: Define operations
operations = {
    "+": lambda a, b: a + b,
    "-": lambda a, b: a - b,
    "*": lambda a, b: a * b,
    "/": lambda a, b: a / b if b != 0 else "Error: Division by zero"
}

# Step 2: Define the calculate() function
def calculate(num1, operator, num2):
    if operator in operations:
        return operations[operator](num1, num2)
    else:
        return "Error: Invalid operator"

# Step 3: Main input loop
while True:
    try:
        num1 = float(input("Enter first number: "))
        operator = input("Enter operator (+, -, *, /): ").strip()
        num2 = float(input("Enter second number: "))

        # Step 4: Calculate and print
        result = calculate(num1, operator, num2)
        print("Result:", result)

    except ValueError:
        print("Error: Please enter valid numbers only.")

    # Ask to continue
    again = input("Do you want to perform another calculation? (y/n): ").lower().strip()
    if again != "y":
        print("Goodbye!")
        break