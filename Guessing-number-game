import random

MIN_NUMBER = 1
MAX_NUMBER = 100

while True:
    secret = random.randint(MIN_NUMBER, MAX_NUMBER)
    attempts = 0

    print(f"I picked a number between {MIN_NUMBER} and {MAX_NUMBER}.")

    while True:
        while True:
            try:
                answer = int(input("Guess the number: "))
                if MIN_NUMBER <= answer <= MAX_NUMBER:
                    break
                print(f"Please enter a number between {MIN_NUMBER} and {MAX_NUMBER}.")
            except ValueError:
                print("Please enter a valid number.")

        attempts += 1

        if answer > secret:
            print("Too high!")
        elif answer < secret:
            print("Too low!")
        else:
            print(f"🎉 You got it in {attempts} attempts!")
            break

    while True:
        again = input("Play again? (y/n): ").strip().lower()
        if again in ['y', 'n']:
            break
        print("Please enter 'y' or 'n'.")

    if again == 'n':
        print("Goodbye!")
        break
