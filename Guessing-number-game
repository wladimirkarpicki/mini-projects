import random

while True:  # Outer loop: restart the game

    secret = random.randint(1, 100)
    attempts = 0

    print("I picked a number between 1 and 100.")

    while True:  # Inner loop: guessing

        while True:  # Input validation loop
            try:
                answer = int(input("Guess the number: "))
                break
            except:
                print("Please enter a valid number.")

        attempts += 1

        if answer > secret:
            print("Too high!")

        elif answer < secret:
            print("Too low!")

        else:
            print("You got it!")
            print(f"You needed {attempts} attempts.")
            break  # Exit guessing loop

    again = input("Play again? (y/n): ")

    if again.lower() == "n":
        print("Goodbye!")
        break  # Exit game loop
